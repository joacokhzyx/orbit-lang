{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Orbit",
  "scopeName": "source.orbit",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#directives" },
    { "include": "#http-methods" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.orbit",
          "match": "//.*$"
        },
        {
          "name": "comment.block.orbit",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "entity.name.tag.annotation.orbit",
          "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.orbit",
          "match": "\\b(port|cors|database|kynx|rate_limit|per_minute|per_second)\\b"
        }
      ]
    },
    "http-methods": {
      "patterns": [
        {
          "name": "keyword.operator.http-method.orbit",
          "match": "\\b(GET|POST|PUT|DELETE|PATCH|OPTIONS|HEAD)\\b"
        }
      ]
    },
    "keywords-control": {
      "patterns": [
        {
          "name": "keyword.control.orbit",
          "match": "\\b(if|else|match|rescue|return|try|catch|import|export|as)\\b"
        }
      ]
    },
    "keywords-declaration": {
      "patterns": [
        {
          "name": "keyword.declaration.orbit",
          "match": "\\b(model|route|val|fn|pub|type|struct|enum)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.orbit",
          "match": "\\b(Int|Float|String|Boolean|List|Map|Void|Any|DateTime)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.orbit",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.orbit",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.orbit",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.orbit",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.orbit",
          "match": "(==|!=|<=|>=|->|=>|\\+=|-=|\\*=|/=|&&|\\|\\||=|\\+|-|\\*|/|%|<|>|!|\\?)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.orbit",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  }
}
