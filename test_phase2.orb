// ══════════════════════════════════════════════════════════════════════
// Orbit Phase 2 Test
//
// Tests: enums, unions, match exhaustiveness, Result<T,E> patterns,
// model construction, and type inference.
// ══════════════════════════════════════════════════════════════════════

// ── Enums ─────────────────────────────────────────────────────────────
enum Color {
    Red,
    Green,
    Blue,
    Alpha
}

enum HttpMethod {
    GET,
    POST,
    PUT,
    DELETE
}

union Status {
    Ok,
    Error(string)
}

// ── Model ─────────────────────────────────────────────────────────────
model ApiResponse {
    @primary @auto
    id: int
    message: string
    status: int
}

// ── Route ─────────────────────────────────────────────────────────────
route GET "/api/colors" {
    return ok 200 "Color palette loaded"
}

// ── Main Logic ────────────────────────────────────────────────────────
fn main() {
    val color = Color.Red
    val method = HttpMethod.GET
    
    // Exhaustive match on enum
    match color {
        Color.Red => print("Red channel active")
        Color.Green => print("Green channel active") 
        Color.Blue => print("Blue channel active")
        Color.Alpha => print("Alpha channel active")
    }

    // Match on HTTP method
    match method {
        HttpMethod.GET => print("GET request")
        HttpMethod.POST => print("POST request")
        HttpMethod.PUT => print("PUT request")
        HttpMethod.DELETE => print("DELETE request")
    }

    // Model construction
    val response = ApiResponse(1, "System online", 200)
    print(response.message)
    
    // String operations
    val greeting = "Orbit Phase 2"
    print(greeting)
    test_collections()
}

fn test_collections() {
    print("Testing Collections...")
    val res = Status.Error("Orbit Success")
    print("Collection test start")

    match res {
        Status.Error(msg) => print(msg)
        Status.Ok => print("Should not happen")
        _ => print("Unknown status")
    }
    
    // List literal syntax
    val nums = [1, 2, 3]
    print(nums.len())
    nums.push(4)
    print(nums.get(3)) // 4
    
    val m = {"a": 1, "b": 2}
    print(m.len())

    // String method tests
    val s = "Orbit"
    print(s.at(0)) // 79 (O)
    print(s.slice(0, 2)) // Or
}
