{
  "name": "professional-baseline",
  "description": "Controlled HTTP stress profile for Orbit pre-self-hosting validation",
  "url": "http://127.0.0.1:3000/health",
  "method": "GET",
  "warmup_seconds": 8,
  "test_seconds": 20,
  "timeout_ms": 3000,
  "concurrency": [1, 8, 32, 128, 256],
  "stress_failure_criteria": {
    "max_error_rate_pct": 1.0,
    "max_p99_ms": 250
  }
}
